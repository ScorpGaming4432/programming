{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cppbuild",
			"label": "C: tcc.exe build and run active file",
			"command": "tcc.exe",
			"args": [
				"-run",
				"${fileBasename}"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"detail": "compiler: tcc.exe"
		}
	]
}